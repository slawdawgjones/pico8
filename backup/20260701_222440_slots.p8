version 43
__lua__
--gameloop 

function _init()
cls(1)
print("welcome to slots!",20,64,10)
print("press z to roll slots")
end

function _update()
	if btnp(4) then rollslots() end
end

function _draw()

	results()
end
-->8
--slots logic

slots={}

function rollslots()
	slots.a=flr(rnd(4))
	slots.b=flr(rnd(4))
	slots.c=flr(rnd(4))
end

function results()
	print(slots.a)
	print(slots.b)
	print(slots.c)
end
