pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--gameloop

gamestate=0
--0 pre-start
--1 play
--2 gameover
--3 win

framecolor=8 --starting frame color
frameswap=6 --when playing 


function _init()
	cls()
	local text="press ❎ to start"
	local title="space gunman"
	makeframe()
	gamestate=0
	print(title,hcenter(title),vcenter(title)-25,8)
	print(text,hcenter(text),vcenter(text),8)
end

function _update()	
	if gamestate==0 and btn(4) then gamestate=1 end
		spawnplayer()
	if worldstate==1 then 
	end
end

function _draw()
	animateplayer()
	if gamestate==1
	then cls()
		framecolor=12
		spawnplayer()
	 moveplayer()
	end
		print(gamestate,0,0)
end
-->8
--player

player={}
player.x=58
player.y=100
player.spr=3
player.speed=1
player.timing=.25

function spawnplayer()
	spr(player.spr,player.x,player.y)
end

function animateplayer()
	if player.spr<=3.5
		then	player.spr+=player.timing
 else player.spr=1 end
end

function moveplayer()
	if btn(0) then player.x-=player.speed 
 elseif btn(1) then player.x+=player.speed
	end
end
-->8
--world generation

function asteroids()
end

function comets()
end

function enemies()
end
-->8
--utilities

function hcenter(s)
	return 64-#s*2
end

function vcenter(s)
	return 61
end

function makeframe()
	rect(0,0,127,127,framecolor)
end
